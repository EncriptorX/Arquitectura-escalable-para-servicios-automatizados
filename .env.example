# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (Public)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# INTELIGENCIA ARTIFICIAL - DEEPSEEK
# ============================================

# API Key de DeepSeek para generación de reportes con IA
# Obtener en: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============================================
# STRIPE CONFIGURATION
# ============================================

# Stripe Publishable Key (Frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ============================================
# CONFIGURACIÓN DE CLOUDFLARE
# ============================================

# API Token de Cloudflare
# Obtener en: https://dash.cloudflare.com/profile/api-tokens
# Permisos necesarios:
#   - Zone:Read
#   - Zone Settings:Edit
#   - DNS:Edit
#   - Firewall Services:Edit
CF_API_TOKEN=your_cloudflare_api_token_here

# Zone ID de tu dominio en Cloudflare
# Encontrar en: Dashboard de Cloudflare > Selecciona tu dominio > Barra lateral derecha
CF_ZONE_ID=your_cloudflare_zone_id_here

# ============================================
# CONFIGURACIÓN DE TURNSTILE
# ============================================

# Turnstile Site Key (Frontend)
# Obtener en: https://dash.cloudflare.com > Turnstile
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Turnstile Secret Key (Backend)
# Obtener en: https://dash.cloudflare.com > Turnstile
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ============================================
# APP CONFIGURATION
# ============================================

# App Name
VITE_APP_NAME=CAS Platform

# App URL
VITE_APP_URL=http://localhost:5173

# ============================================
# ADMINISTRACIÓN
# ============================================

# API Key para endpoints administrativos (toggle-service / toggle-protection)
ADMIN_API_KEY=your_admin_api_key_here

# ============================================
# CONFIGURACIÓN CSaaS (Cloudflare for SaaS)
# ============================================

# Zona principal para subdominios CSaaS
# Esta es la zona donde se crearán los subdominios automáticos
CSAAS_ZONE=cubansaas.tech

# CNAME Target para Custom Hostnames
# Todos los Custom Hostnames apuntarán a este target
CSAAS_CNAME_TARGET=customers.cubansaas.tech

# ============================================
# NOTAS
# ============================================

# Host allowlist (coma-separados). Si se omite, se usan valores por defecto.
# Ejemplo: localhost,127.0.0.1,*.vercel.app,cubansaas.tech,*.cubansaas.tech
ALLOWED_HOSTS=localhost,127.0.0.1,*.vercel.app,cubansaas.tech,*.cubansaas.tech

# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# 4. Para producción en Vercel, configura estas variables en:
#    Vercel Dashboard > Settings > Environment Variables
# 5. Para CSaaS, el sistema creará subdominios bajo cubansaas.tech automáticamente.
# 6. Asegúrate de que cubansaas.tech esté delegado a Cloudflare (nameservers configurados).
