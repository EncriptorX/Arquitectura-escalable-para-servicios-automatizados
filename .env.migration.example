# ============================================
# DATABASE MIGRATION CONFIGURATION
# ============================================

# Supabase Database Connection String
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Format: postgresql://postgres:[YOUR-PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# Example:
# DATABASE_URL=postgresql://postgres:mypassword123@db.abcdefghijklmnop.supabase.co:5432/postgres

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file as .env.migration
# 2. Replace the DATABASE_URL with your actual Supabase connection string
# 3. Run: node scripts/run-migrations.js migrate